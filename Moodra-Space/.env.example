# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── Database (Supabase Postgres via connection pooler) ───────────────────────
# Format: postgresql://postgres.<project-ref>:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.<project-ref>:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# ─── Sessions & Encryption ──────────────────────────────────────────────────
# Used both for express-session cookies and AES-256-GCM encryption of stored
# OpenAI API keys. Generate with: openssl rand -hex 32
# WARNING: changing this value invalidates all existing encrypted API keys in the DB.
SESSION_SECRET=replace-with-a-long-random-string

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Full URL that Google will redirect to after login.
# Must be added to the "Authorised redirect URIs" list in your Google OAuth app.
# Example: https://your-app-name.onrender.com/api/auth/google/callback
GOOGLE_CALLBACK_URL=https://your-app-name.onrender.com/api/auth/google/callback

# ─── Supabase (optional — only if you use Supabase Storage or client SDK) ───
# If you only use Supabase as a Postgres host (via DATABASE_URL), leave these blank.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# ─── OpenAI (optional — users supply their own key via the UI) ───────────────
# Only needed if you want a server-level fallback key.
OPENAI_API_KEY=

# ─── Cyrillic Renderer (optional) ───────────────────────────────────────────
# Port for the WeasyPrint-based PDF renderer. Defaults to 3001 if not set.
CYRILLIC_RENDERER_PORT=3001
